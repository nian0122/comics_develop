{
  "name": "comic-reader-frontend",
  "version": "1.0.0",
  "type": "module",
  "description": "本地漫画阅读器前端",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
