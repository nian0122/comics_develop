    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^15.0.0",
    "jsdom": "^24.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "pinia": "^2.3.1",
